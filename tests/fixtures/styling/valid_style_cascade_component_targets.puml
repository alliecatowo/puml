@startuml
skinparam ComponentBackgroundColor #ffffff
skinparam ComponentBorderColor #1e293b
skinparam ComponentFontColor #0f172a

<style>
componentDiagram {
  component<<service>> {
    BackgroundColor #dcfce7
    BorderColor #15803d
    FontColor #14532d
  }
  interface {
    BackgroundColor #fef3c7
    BorderColor #b45309
    FontColor #92400e
  }
  port {
    BackgroundColor #e0f2fe
    BorderColor #0369a1
