' Merged C4 Container compatibility surface.
' Descriptions are emitted as block members so the C4 renderer can display them
' as italic text below the node name.  Tech tags are appended to the Rel label in
' [brackets], matching the PlantUML C4 visual convention.
' %unquote() strips the outer quotes from quoted string args before expansion.

!procedure Person($alias, $label, $descr="")
!if $descr != ""
object %unquote($label) as $alias <<person>> {
%unquote($descr)
}
!else
object %unquote($label) as $alias <<person>>
!endif
!endprocedure

!procedure Person_Ext($alias, $label, $descr="")
!if $descr != ""
object %unquote($label) as $alias <<external-person>> {
%unquote($descr)
}
!else
object %unquote($label) as $alias <<external-person>>
!endif
!endprocedure

