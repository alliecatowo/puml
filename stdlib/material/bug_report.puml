' Deterministic Material bug_report icon stub.
!include <material/common>

!procedure MA_BUG_REPORT($a, $b=bug_report, $c=, $d=, $e=__PUML_MISSING__)
!if $e != __PUML_MISSING__
MaterialIcon($c, bug_report, %unquote($e), "")
!else
MaterialIcon($a, bug_report, %unquote($b), %unquote($c))
!endif
!endprocedure
