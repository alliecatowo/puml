' PicoUML stdlib stub — tupadr3 / Font-Awesome icon macros

!procedure FA_ICON($alias, $label, $icon="fa")
object $label as $alias <<fa-$icon>>
!endprocedure

!procedure FONT_AWESOME($alias, $label, $icon="fa")
object $label as $alias <<fa-$icon>>
!endprocedure

!procedure DEV_ICON($alias, $label, $icon="dev")
object $label as $alias <<dev-$icon>>
!endprocedure

!procedure Rel($from, $to, $label)
$from --> $to : $label
!endprocedure
