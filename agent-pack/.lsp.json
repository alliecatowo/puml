{
  "name": "puml-lsp",
  "version": "0.0.1",
  "transport": "stdio",
  "command": "bin/puml-lsp",
  "languages": [
    {
      "id": "puml",
      "extensions": [".puml", ".plantuml", ".iuml"]
    }
  ],
  "capabilities": [
    "textDocument/publishDiagnostics",
    "textDocument/semanticTokens/full",
    "workspace/executeCommand"
  ],
  "commands": ["puml.applyFormat", "puml.renderSvg"]
}
