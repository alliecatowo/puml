' Architecture Overview: PUML high-level component diagram
' Simplified overview tuned for readable generated output.

@startuml

skinparam componentStyle rectangle
skinparam packageStyle frame

package "Transports" {
  component [CLI] as CLI
  component [LSP] as LSP
  component [WASM] as WASM
}

package "Frontends" {
  component [Adapters] as Frontends
}

package "Shared Services" {
  component [Preprocessor] as Preproc
  component [Language Service] as LangSvc
  component [Diagnostics + Theme] as RenderSupport
}

package "Pipeline Core" {
  component [Parser] as Parser
  component [AST] as AST
  component [Normalizer] as Normalizer
  component [Renderer] as Renderer
}

package "Output Formats" {
  component [SVG / PNG / Text] as Outputs
}

CLI --> Frontends
CLI --> Preproc
LSP --> LangSvc
WASM --> LangSvc

Frontends --> Parser
Preproc --> Parser
LangSvc --> Parser
LangSvc --> RenderSupport
RenderSupport --> Renderer

Parser --> AST
AST --> Normalizer
Normalizer --> Renderer
Renderer --> Outputs

@enduml
