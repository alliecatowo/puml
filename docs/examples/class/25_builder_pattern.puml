@startuml
title Builder Pattern
class HttpRequest {
  -url: String
  -method: String
  -body: String
}
class Builder {
  -url: String
  -method: String
  +url(url: String): Builder
  +method(m: String): Builder
  +body(body: String): Builder
  +build(): HttpRequest
}
Builder --> HttpRequest : builds
@enduml
