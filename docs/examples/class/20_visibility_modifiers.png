<svg xmlns="http://www.w3.org/2000/svg" width="1064" height="312" viewBox="0 0 1064 312"><rect width="100%" height="100%" fill="#ffffff"/><defs><marker id="arrow-open" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="10" markerHeight="10" markerUnits="userSpaceOnUse" orient="auto-start-reverse"><path d="M0,0 L10,5 L0,10" fill="none" stroke="#1e293b" stroke-width="1.5"/></marker><marker id="arrow-triangle" viewBox="0 0 16 16" refX="15" refY="8" markerWidth="16" markerHeight="16" markerUnits="userSpaceOnUse" orient="auto-start-reverse"><polygon points="0,1 14,8 0,15" fill="#ffffff" stroke="#1e293b" stroke-width="1.5" fill-rule="nonzero"/></marker><marker id="arrow-diamond-filled" viewBox="0 0 14 10" refX="13" refY="5" markerWidth="14" markerHeight="10" markerUnits="userSpaceOnUse" orient="auto-start-reverse"><path d="M0,5 L7,0 L14,5 L7,10 z" fill="#1e293b" stroke="#1e293b" stroke-width="1"/></marker><marker id="arrow-diamond-open" viewBox="0 0 14 10" refX="13" refY="5" markerWidth="14" markerHeight="10" markerUnits="userSpaceOnUse" orient="auto-start-reverse"><path d="M0,5 L7,0 L14,5 L7,10 z" fill="#ffffff" stroke="#1e293b" stroke-width="1"/></marker></defs><text x="32" y="32" font-family="monospace" font-size="18" font-weight="600" fill="#0f172a">Visibility and Modifiers</text><rect x="32" y="66" width="280" height="206" rx="4" ry="4" fill="#ffffff" stroke="#1e293b" stroke-width="1.5"/><rect x="32" y="66" width="280" height="30" rx="4" ry="4" fill="#dbeafe" stroke="#1e293b" stroke-width="1.5"/><line x1="32" y1="96" x2="312" y2="96" stroke="#1e293b" stroke-width="1"/><text x="172" y="87" text-anchor="middle" font-family="monospace" font-size="13" font-weight="600" fill="#0f172a">Example</text><text class="uml-member" data-uml-visibility="public" x="42" y="112" font-family="monospace" font-size="11" fill="#16a34a">+publicField: String</text><text class="uml-member" data-uml-visibility="private" x="42" y="128" font-family="monospace" font-size="11" fill="#dc2626">-privateField: int</text><text class="uml-member" data-uml-visibility="protected" x="42" y="144" font-family="monospace" font-size="11" fill="#d97706">#protectedField: boolean</text><text class="uml-member" data-uml-visibility="package" x="42" y="160" font-family="monospace" font-size="11" fill="#7c3aed">~packageField: double</text><text class="uml-member" data-uml-visibility="public" x="42" y="176" font-family="monospace" font-size="11" fill="#16a34a" text-decoration="underline">+CLASS_CONSTANT: String</text><text class="uml-member" data-uml-visibility="private" x="42" y="192" font-family="monospace" font-size="11" fill="#dc2626" text-decoration="underline">-instanceCount: int</text><line x1="32" y1="200" x2="312" y2="200" stroke="#1e293b" stroke-width="1"/><text class="uml-member" data-uml-visibility="public" x="42" y="208" font-family="monospace" font-size="11" fill="#16a34a">+publicMethod(): void</text><text class="uml-member" data-uml-visibility="private" x="42" y="224" font-family="monospace" font-size="11" fill="#dc2626">-privateMethod(): void</text><text class="uml-member" data-uml-visibility="protected" x="42" y="240" font-family="monospace" font-size="11" fill="#d97706" font-style="italic">#abstractMethod(): String</text><text class="uml-member" data-uml-visibility="public" x="42" y="256" font-family="monospace" font-size="11" fill="#16a34a" text-decoration="underline">+staticMethod(): int</text></svg>