@startuml
title Event Sourcing
class Event {
  +aggregateId(): String
  +timestamp(): Instant
}
class EventStore {
  +append(event: Event): void
  +load(id: String): List
}
class Aggregate {
  -id: String
  -version: int
  +apply(event: Event): void
}
class OrderCreated {
  +orderId: String
  +customerId: String
}
class OrderAggregate {
  -status: String
}
OrderCreated <|-- Event
OrderAggregate <|-- Aggregate
EventStore --> Event
@enduml
