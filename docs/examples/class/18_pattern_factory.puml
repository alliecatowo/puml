@startuml
title Factory Pattern
class AnimalFactory {
  +create(): Animal
}
class Animal {
  +speak(): String
}
class DogFactory {
  +create(): Animal
}
class CatFactory {
  +create(): Animal
}
class Dog {
  +speak(): String
}
class Cat {
  +speak(): String
}
AnimalFactory <|-- DogFactory
AnimalFactory <|-- CatFactory
Animal <|-- Dog
Animal <|-- Cat
DogFactory --> Dog
CatFactory --> Cat
@enduml
