@startuml
title Enum and Annotation Stereotypes
enum Status {
  PENDING
  ACTIVE
  INACTIVE
  DELETED
}
enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}
class Task {
  -id: Long
  -title: String
  -status: Status
  -priority: Priority
  +execute(): void
}
Task --> Status
Task --> Priority
@enduml
