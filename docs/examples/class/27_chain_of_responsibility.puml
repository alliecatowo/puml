@startuml
title Chain of Responsibility
class Handler {
  -next: Handler
  +handle(request): Response
}
class AuthHandler {
  +handle(request): Response
}
class RateLimitHandler {
  +handle(request): Response
}
class BusinessHandler {
  +handle(request): Response
}
Handler <|-- AuthHandler
Handler <|-- RateLimitHandler
Handler <|-- BusinessHandler
AuthHandler --> RateLimitHandler : next
RateLimitHandler --> BusinessHandler : next
@enduml
