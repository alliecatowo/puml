@startuml
title Parallel regions with shared events
state MediaPlayer {
  state Playing
  state Paused
  state Stopped
  Playing --> Paused : pause
  Paused --> Playing : resume
  Playing --> Stopped : stop
  Paused --> Stopped : stop
  Stopped --> Playing : play
  --
  state Normal
  state Muted
  Normal --> Muted : mute
  Muted --> Normal : unmute
  --
  [*] --> EQOff
  state EQOff
  state EQOn {
    EQOn : do / applyBands
  }
  EQOff --> EQOn : enableEQ
  EQOn --> EQOff : disableEQ
}
[*] --> MediaPlayer
MediaPlayer --> [*] : powerOff
@enduml
