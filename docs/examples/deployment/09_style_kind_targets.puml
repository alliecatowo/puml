@startuml
title Deployment style selectors by kind

<style>
deploymentDiagram {
  node {
    BackgroundColor #dbeafe
    BorderColor #2563eb
    FontColor #1e3a8a
  }
  database {
    BackgroundColor #fef3c7
    BorderColor #b45309
    FontColor #78350f
  }
  queue {
    BackgroundColor #fae8ff
    BorderColor #a21caf
    FontColor #701a75
  }
  cloud {
    BackgroundColor #ecfeff
    BorderColor #0891b2
    FontColor #164e63
  }
}
</style>

cloud Edge
node Web
queue Jobs
database DB
Edge --> Web : route
Web --> Jobs : enqueue
Jobs --> DB : persist
@enduml
