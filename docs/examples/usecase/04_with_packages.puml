@startuml
actor Customer
actor Manager

rectangle "Online Store" {
  usecase Browse
  usecase AddToCart
  usecase Checkout
}

rectangle "Back Office" {
  usecase ManageProducts as MP
  usecase ManageOrders as MO
}

Customer --> Browse
Customer --> AddToCart
Customer --> Checkout
Manager --> MP
Manager --> MO
Browse --> AddToCart
AddToCart --> Checkout
MP --> MO : depends
@enduml
