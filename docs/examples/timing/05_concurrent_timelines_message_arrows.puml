@startuml
title Concurrent timelines: CPU, cache, and I/O
concise "CPU" as CPU
concise "Cache L1" as L1
concise "Memory Bus" as MEM
concise "I/O Controller" as IO
clock "System Clock" as CLK with period 1

@0
CPU is "Fetch"
L1 is "Warm"
MEM is "Idle"
IO is "Idle"
CLK is low

@1
CLK is high
CPU is "Decode"

@2
CLK is low
CPU is "Execute"
L1 is "Hit"

@3
CLK is high
CPU is "Stall"
L1 is "Miss"
MEM is "Read"
CPU -> MEM : ReadReq

@4
CLK is low
MEM is "Wait"

@5
CLK is high
MEM is "Done"
CPU is "WriteBack"
L1 is "Fill"
MEM -> CPU : ReadResp

@6
CLK is low
CPU is "Fetch"
IO is "DmaStart"
CPU -> MEM@+1 : DmaKick

@7
CLK is high
MEM is "DmaWrite"
IO is "DmaActive"
MEM -> IO : DmaAck

@8
CLK is low
MEM is "Idle"
IO is "Idle"
CPU is "Decode"

@enduml
